@page "{id:guid}"
@model OPCBS.Web.Pages.Doctors.RatingsModel
@{
    ViewData["Title"] = "Doctor Ratings";
}

<section class="mb-section">
    <div class="mb-page-header">
        <h1>Reviews for @Model.DoctorName</h1>
        <a asp-page="/Doctors/Details" asp-route-id="@Model.DoctorId" class="btn btn-outline-primary btn-sm">Back to Profile</a>
    </div>
    @if (Model.Reviews.Any())
    {
        @foreach (var review in Model.Reviews)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold">@review.PatientName</span>
                        <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>
                    <partial name="_RatingStars" view-data='@(new ViewDataDictionary(ViewData) { { "Rating", (double)review.Rating }, { "ReviewCount", 0 } })' />
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <p class="text-muted mt-2 mb-0">@review.Comment</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <partial name="_EmptyState" view-data='@(new ViewDataDictionary(ViewData) { { "EmptyIcon", "bi-star" }, { "EmptyTitle", "No reviews yet" }, { "EmptyMessage", "This doctor has not received any reviews." } })' />
    }
</section>
