@page
@model OPCBS.Web.Pages.Doctor.TreatmentPackages.CreateModel
@{ ViewData["Title"] = "Tạo gói trị liệu"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Tạo gói trị liệu</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>
@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }
<div class="card border-0 shadow-sm"><div class="card-body">
    <form method="post">
        <div class="row g-3">
            <div class="col-md-8"><label class="form-label">Tên gói <span class="text-danger">*</span></label><input asp-for="Input.Title" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">Số phiên</label><input type="number" asp-for="Input.TotalSessions" class="form-control" min="1" /></div>
            <div class="col-12"><label class="form-label">Mô tả</label><textarea asp-for="Input.Description" class="form-control" rows="3"></textarea></div>
            <div class="col-md-6"><label class="form-label">Giá (₫)</label><input type="number" asp-for="Input.Price" class="form-control" /></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Tạo</button> <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a></div>
    </form>
</div></div>
