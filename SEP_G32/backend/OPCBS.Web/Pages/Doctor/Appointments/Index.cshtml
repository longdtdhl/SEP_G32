@page
@model OPCBS.Web.Pages.Doctor.Appointments.IndexModel
@{
    ViewData["Title"] = "Quản lý lịch hẹn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1>Quản lý lịch hẹn</h1>
</div>

@if (Model.Error != null)
{
    <div class="alert alert-warning">@Model.Error</div>
}

<!-- Filters -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Trạng thái</label>
                <select asp-for="Status" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    <option value="Pending">Chờ duyệt</option>
                    <option value="Approved">Đã duyệt</option>
                    <option value="Completed">Hoàn thành</option>
                    <option value="Cancelled">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small">Tìm kiếm</label>
                <input asp-for="Search" class="form-control form-control-sm" placeholder="Tên bệnh nhân..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i> Lọc</button>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Bệnh nhân</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th>Phí</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Appointments.Any())
                    {
                        @foreach (var apt in Model.Appointments)
                        {
                            var badgeClass = apt.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "Approved" => "bg-info text-white",
                                "Completed" => "bg-success",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td>
                                    <strong>@(apt.PatientName ?? "N/A")</strong>
                                    @if (!string.IsNullOrEmpty(apt.Specialization))
                                    {
                                        <br /><small class="text-muted">@apt.Specialization</small>
                                    }
                                </td>
                                <td>
                                    @apt.StartAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td><span class="badge @badgeClass">@apt.Status</span></td>
                                <td>@(apt.Fee?.ToString("N0") ?? "-") ₫</td>
                                <td class="text-end">
                                    <a asp-page="Details" asp-route-id="@apt.Id" class="btn btn-sm btn-outline-primary" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (apt.Status == "Pending")
                                    {
                                        <form method="post" asp-page-handler="Confirm" class="d-inline">
                                            <input type="hidden" name="id" value="@apt.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Duyệt"><i class="bi bi-check-lg"></i></button>
                                        </form>
                                    }
                                    @if (apt.Status == "Approved")
                                    {
                                        <form method="post" asp-page-handler="Complete" class="d-inline">
                                            <input type="hidden" name="id" value="@apt.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-info" title="Hoàn thành"><i class="bi bi-check-all"></i></button>
                                        </form>
                                    }
                                    @if (apt.Status is "Pending" or "Approved")
                                    {
                                        <form method="post" asp-page-handler="Cancel" class="d-inline">
                                            <input type="hidden" name="id" value="@apt.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Hủy" onclick="return confirm('Bạn có chắc muốn hủy lịch hẹn này?')"><i class="bi bi-x-lg"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">Không có lịch hẹn nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="Index" asp-route-page="@i" asp-route-status="@Model.Status" asp-route-search="@Model.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
