@page
@model OPCBS.Web.Pages.Doctor.ConsultationRecords.CreateModel
@{
    ViewData["Title"] = "Tạo hồ sơ tư vấn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Tạo hồ sơ tư vấn</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Input.AppointmentId" />
            <div class="row g-3">
                @if (!Model.AppointmentId.HasValue)
                {
                    <div class="col-12">
                        <label class="form-label">Appointment ID <span class="text-danger">*</span></label>
                        <input asp-for="Input.AppointmentId" class="form-control" />
                    </div>
                }
                <div class="col-12">
                    <label class="form-label">Chẩn đoán</label>
                    <input asp-for="Input.Diagnosis" class="form-control" placeholder="VD: Rối loạn lo âu lan tỏa..." />
                </div>
                <div class="col-12">
                    <label class="form-label">Ghi chú tư vấn</label>
                    <textarea asp-for="Input.Notes" class="form-control" rows="4" placeholder="Ghi chú chi tiết về buổi tư vấn..."></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Đơn thuốc / Chỉ định</label>
                    <textarea asp-for="Input.Prescription" class="form-control" rows="2" placeholder="Thuốc hoặc chỉ định (nếu có)..."></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Khuyến nghị</label>
                    <textarea asp-for="Input.Recommendations" class="form-control" rows="3" placeholder="Khuyến nghị cho bệnh nhân..."></textarea>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu hồ sơ</button>
                <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </form>
    </div>
</div>
