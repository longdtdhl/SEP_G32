@page
@model OPCBS.Web.Pages.Doctor.ConsultationRecords.IndexModel
@{
    ViewData["Title"] = "Hồ sơ tư vấn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Hồ sơ tư vấn</h1>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Tạo mới</a>
</div>

@if (Model.Error != null) { <div class="alert alert-warning">@Model.Error</div> }

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Bệnh nhân</th><th>Chẩn đoán</th><th>Ngày tư vấn</th><th class="text-end">Hành động</th></tr>
                </thead>
                <tbody>
                    @if (Model.Records.Any())
                    {
                        @foreach (var r in Model.Records)
                        {
                            <tr>
                                <td><strong>@(r.PatientName ?? "N/A")</strong></td>
                                <td>@(r.Diagnosis ?? "-")</td>
                                <td>@r.ConsultationDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <a asp-page="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có hồ sơ tư vấn nào</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
{
    <nav class="mt-3"><ul class="pagination justify-content-center">
        @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a class="page-link" asp-page="Index" asp-route-page="@i">@i</a>
            </li>
        }
    </ul></nav>
}
