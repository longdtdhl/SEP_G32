@page "{id:guid}"
@model OPCBS.Web.Pages.Doctor.ConsultationRecords.EditModel
@{
    ViewData["Title"] = "Chi tiết hồ sơ tư vấn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Hồ sơ tư vấn</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

@if (Model.Record != null)
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white"><h5 class="mb-0">Thông tin</h5></div>
        <div class="card-body">
            <div class="row mb-2"><div class="col-sm-3 text-muted">Bệnh nhân</div><div class="col-sm-9"><strong>@(Model.Record.PatientName ?? "N/A")</strong></div></div>
            <div class="row mb-2"><div class="col-sm-3 text-muted">Ngày tư vấn</div><div class="col-sm-9">@Model.Record.ConsultationDate.ToString("dd/MM/yyyy")</div></div>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white"><h5 class="mb-0">Chỉnh sửa hồ sơ</h5></div>
    <div class="card-body">
        <form method="post" asp-route-id="@Model.RecordId">
            <div class="mb-3">
                <label class="form-label">Chẩn đoán</label>
                <input asp-for="Input.Diagnosis" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">Ghi chú tư vấn</label>
                <textarea asp-for="Input.Notes" class="form-control" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Đơn thuốc</label>
                <textarea asp-for="Input.Prescription" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Khuyến nghị</label>
                <textarea asp-for="Input.Recommendations" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Cập nhật</button>
            <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
        </form>
    </div>
</div>
