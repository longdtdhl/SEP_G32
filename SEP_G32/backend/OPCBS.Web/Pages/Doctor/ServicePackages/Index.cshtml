@page
@model OPCBS.Web.Pages.Doctor.ServicePackages.IndexModel
@{ ViewData["Title"] = "Gói dịch vụ"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header"><h1>Gói dịch vụ</h1>
    <p class="text-muted">Chọn gói phù hợp để sử dụng các tính năng của hệ thống</p>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }
@if (Model.Success != null) { <div class="alert alert-success">@Model.Success</div> }

@if (Model.CurrentSubscription != null)
{
    <div class="alert alert-info mb-4">
        <i class="bi bi-check-circle me-1"></i>
        Bạn đang sử dụng gói <strong>@(Model.CurrentSubscription.PackageName ?? "N/A")</strong>
        (hết hạn: @Model.CurrentSubscription.EndDate.ToString("dd/MM/yyyy"))
    </div>
}

<div class="row g-4">
    @foreach (var pkg in Model.Packages.Where(p => p.IsActive))
    {
        var isCurrentPkg = Model.CurrentSubscription?.ServicePackageId == pkg.Id;
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100 @(isCurrentPkg ? "border-primary border-2" : "")">
                <div class="card-body text-center">
                    @if (isCurrentPkg)
                    {
                        <span class="badge bg-primary mb-2">Đang sử dụng</span>
                    }
                    <h4 class="card-title">@pkg.Name</h4>
                    <div class="my-3">
                        <span style="font-size:2rem;font-weight:700;color:var(--mb-primary)">@pkg.Price.ToString("N0")</span>
                        <span class="text-muted"> ₫</span>
                    </div>
                    <p class="text-muted small">@(pkg.Description ?? "")</p>
                    <ul class="list-unstyled text-start mb-3">
                        <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>@pkg.DurationDays ngày sử dụng</li>
                        <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>@pkg.MaxAppointments lịch hẹn</li>
                        @foreach (var f in pkg.Features)
                        {
                            <li class="mb-1"><i class="bi bi-check-circle-fill text-success me-1"></i>@f</li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-3">
                    @if (!isCurrentPkg)
                    {
                        <form method="post" asp-page-handler="Subscribe">
                            <input type="hidden" name="packageId" value="@pkg.Id" />
                            <button type="submit" class="btn btn-primary w-100">Đăng ký ngay</button>
                        </form>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary w-100" disabled>Đang sử dụng</button>
                    }
                </div>
            </div>
        </div>
    }
</div>
