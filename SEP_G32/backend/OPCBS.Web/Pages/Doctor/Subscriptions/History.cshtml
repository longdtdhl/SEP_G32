@page
@model OPCBS.Web.Pages.Doctor.Subscriptions.HistoryModel
@{ ViewData["Title"] = "Lịch sử đăng ký"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Lịch sử đăng ký</h1>
    <a asp-page="Status" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="card border-0 shadow-sm"><div class="card-body p-0">
    <div class="table-responsive"><table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Gói</th><th>Trạng thái</th><th>Bắt đầu</th><th>Hết hạn</th><th>Thanh toán</th></tr></thead>
        <tbody>
            @if (Model.History.Any())
            {
                @foreach (var s in Model.History)
                {
                    <tr>
                        <td><strong>@(s.PackageName ?? "N/A")</strong></td>
                        <td><span class="badge @(s.Status == "Active" ? "bg-success" : "bg-secondary")">@(s.Status ?? "N/A")</span></td>
                        <td>@s.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@s.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>@s.AmountPaid.ToString("N0") ₫</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có lịch sử đăng ký</td></tr>
            }
        </tbody>
    </table></div>
</div></div>
