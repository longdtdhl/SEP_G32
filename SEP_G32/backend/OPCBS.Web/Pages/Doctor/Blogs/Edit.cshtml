@page "{id:guid}"
@model OPCBS.Web.Pages.Doctor.Blogs.EditModel
@{ ViewData["Title"] = "Chỉnh sửa bài viết"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Chỉnh sửa bài viết</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>
@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }
@if (Model.CurrentStatus != null)
{
    var badge = Model.CurrentStatus switch { "Draft" => "bg-secondary", "Pending" => "bg-warning text-dark", "Published" => "bg-success", "Rejected" => "bg-danger", _ => "bg-secondary" };
    <div class="mb-3"><span class="badge @badge">@Model.CurrentStatus</span></div>
}
<div class="card border-0 shadow-sm"><div class="card-body">
    <form method="post" asp-route-id="@Model.BlogId">
        <div class="row g-3">
            <div class="col-md-8"><label class="form-label">Tiêu đề</label><input asp-for="Input.Title" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">Danh mục</label><input asp-for="Input.Category" class="form-control" /></div>
            <div class="col-12"><label class="form-label">Tóm tắt</label><textarea asp-for="Input.Summary" class="form-control" rows="2"></textarea></div>
            <div class="col-12"><label class="form-label">Nội dung</label><textarea asp-for="Input.Content" class="form-control" rows="10"></textarea></div>
            <div class="col-md-8"><label class="form-label">URL ảnh bìa</label><input asp-for="Input.ImageUrl" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">Tags</label><input asp-for="TagsInput" class="form-control" /></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Cập nhật</button> <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a></div>
    </form>
</div></div>
