@page
@model OPCBS.Web.Pages.Doctor.Blogs.CreateModel
@{ ViewData["Title"] = "Viết bài mới"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Viết bài mới</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>
@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }
<div class="card border-0 shadow-sm"><div class="card-body">
    <form method="post">
        <div class="row g-3">
            <div class="col-md-8"><label class="form-label">Tiêu đề <span class="text-danger">*</span></label><input asp-for="Input.Title" class="form-control" /></div>
            <div class="col-md-4"><label class="form-label">Danh mục</label><input asp-for="Input.Category" class="form-control" placeholder="VD: Sức khỏe tâm thần" /></div>
            <div class="col-12"><label class="form-label">Tóm tắt</label><textarea asp-for="Input.Summary" class="form-control" rows="2"></textarea></div>
            <div class="col-12"><label class="form-label">Nội dung <span class="text-danger">*</span></label><textarea asp-for="Input.Content" class="form-control" rows="10" placeholder="Viết nội dung bài viết..."></textarea></div>
            <div class="col-md-8"><label class="form-label">URL ảnh bìa</label><input asp-for="Input.ImageUrl" class="form-control" placeholder="https://..." /></div>
            <div class="col-md-4"><label class="form-label">Tags (phân cách bằng dấu phẩy)</label><input asp-for="TagsInput" class="form-control" placeholder="tag1, tag2" /></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Lưu bản nháp</button> <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a></div>
    </form>
</div></div>
