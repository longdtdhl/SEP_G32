@page
@model OPCBS.Web.Pages.Doctor.Schedules.DaysOffModel
@{ ViewData["Title"] = "Quản lý ngày nghỉ"; ViewData["UseDashboardLayout"] = true; }

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Quản lý ngày nghỉ</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="row g-4">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm"><div class="card-header bg-white"><h5 class="mb-0">Thêm ngày nghỉ</h5></div><div class="card-body">
            <form method="post">
                <div class="mb-3"><label class="form-label">Ngày bắt đầu <span class="text-danger">*</span></label><input type="date" asp-for="Input.StartDate" class="form-control" /></div>
                <div class="mb-3"><label class="form-label">Ngày kết thúc</label><input type="date" asp-for="Input.EndDate" class="form-control" /></div>
                <div class="mb-3"><label class="form-label">Lý do</label><input asp-for="Input.Reason" class="form-control" /></div>
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg me-1"></i>Thêm</button>
            </form>
        </div></div>
    </div>
    <div class="col-md-7">
        <div class="card border-0 shadow-sm"><div class="card-header bg-white"><h5 class="mb-0">Danh sách ngày nghỉ</h5></div><div class="card-body p-0">
            <div class="table-responsive"><table class="table table-hover mb-0">
                <thead class="table-light"><tr><th>Ngày</th><th>Lý do</th><th class="text-end">Xóa</th></tr></thead>
                <tbody>
                    @if (Model.DaysOff.Any())
                    {
                        @foreach (var d in Model.DaysOff)
                        {
                            <tr>
                                <td>@d.StartDate.ToString("dd/MM/yyyy") @(d.EndDate != d.StartDate ? $"- {d.EndDate:dd/MM/yyyy}" : "")</td>
                                <td>@(d.Reason ?? "-")</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Delete" class="d-inline">
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa?')"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="text-center py-3 text-muted">Không có ngày nghỉ</td></tr>
                    }
                </tbody>
            </table></div>
        </div></div>
    </div>
</div>
