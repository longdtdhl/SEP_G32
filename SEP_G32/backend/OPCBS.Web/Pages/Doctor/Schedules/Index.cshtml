@page
@model OPCBS.Web.Pages.Doctor.Schedules.IndexModel
@{
    ViewData["Title"] = "Quản lý lịch làm việc";
    ViewData["UseDashboardLayout"] = true;
    var today = DateTime.Today;
    var dayNames = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
    var prevWeek = Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek = Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd");
    var weekNumber = System.Globalization.CultureInfo.InvariantCulture.Calendar.GetWeekOfYear(Model.WeekStart, System.Globalization.CalendarWeekRule.FirstFourDayWeek, DayOfWeek.Monday);
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-calendar-week me-2" style="color:var(--mb-primary);"></i>Quản lý lịch làm việc</h1>
    <div class="d-flex gap-2">
        <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Tạo slot tư vấn</a>
        <a asp-page="DaysOff" class="btn btn-outline-secondary btn-sm"><i class="bi bi-calendar-x me-1"></i>Ngày nghỉ</a>
    </div>
</div>

@if (Model.Success != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@Model.Success<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning">@Model.Error</div> }

<!-- Weekly Calendar -->
<div class="week-calendar shadow-sm">
    <!-- Navigation bar -->
    <div class="wc-nav">
        <div class="d-flex align-items-center gap-2">
            <div class="btn-group btn-group-sm">
                <a asp-page="Index" asp-route-week="@prevWeek" class="btn btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
                <a asp-page="Index" asp-route-week="@nextWeek" class="btn btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
            </div>
        </div>
        <span class="wc-title">@Model.WeekStart.ToString("MMM dd") — @Model.WeekEnd.ToString("MMM dd, yyyy")</span>
        <span class="wc-badge">Tuần @weekNumber</span>
        <div class="ms-auto">
            <a asp-page="Index" class="btn btn-sm btn-outline-primary">Hôm nay</a>
        </div>
    </div>

    <!-- Day headers -->
    <div class="week-calendar-header">
        <div class="wc-time-col"></div>
        @foreach (var day in Model.WeekDays)
        {
            var isToday = day.Date == today;
            var isDayOff = Model.IsDayOff(day);
            <div class="wc-day-col @(isToday ? "today" : "")">
                <div class="wc-day-name">@dayNames[(int)day.DayOfWeek]</div>
                <div class="wc-day-num">@day.Day</div>
                @if (isDayOff)
                {
                    <small class="text-danger" style="font-size:0.6rem;"><i class="bi bi-x-circle"></i> Nghỉ</small>
                }
            </div>
        }
    </div>

    <!-- Time grid -->
    <div class="week-calendar-body">
        @for (int hour = Model.CalStartHour; hour <= Model.CalEndHour; hour++)
        {
            <div class="wc-time-row">
                <div class="wc-time-label">@hour.ToString("00"):00</div>
                @foreach (var day in Model.WeekDays)
                {
                    var isToday = day.Date == today;
                    var isDayOff = Model.IsDayOff(day);
                    var schedules = Model.DayScheduleMap.GetValueOrDefault(day.DayOfWeek, new());

                    <div class="wc-time-cell @(isToday ? "today-col" : "") @(isDayOff ? "opacity-25" : "")">
                        @foreach (var s in schedules)
                        {
                            if (TimeOnly.TryParse(s.StartTime, out var st) && st.Hour == hour)
                            {
                                TimeOnly.TryParse(s.EndTime, out var et);
                                var durationHours = (et.ToTimeSpan() - st.ToTimeSpan()).TotalHours;
                                var heightPx = (int)(durationHours * 64);
                                <div class="wc-slot available" style="top:2px;height:@(heightPx - 4)px;" title="@s.StartTime - @s.EndTime (@(s.SlotDuration)min slots)">
                                    <span class="slot-time">@s.StartTime - @s.EndTime</span>
                                    <span class="slot-label">@(s.SlotDuration) phút/slot</span>
                                    <span class="slot-count">@s.SlotsPerDay slots</span>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Legend & Schedule table -->
<div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="wc-legend">
        <div class="wc-legend-item"><div class="legend-dot" style="background:var(--mb-primary-light);border:1px solid rgba(78,139,112,0.25);"></div>Lịch làm việc</div>
        <div class="wc-legend-item"><div class="legend-dot" style="background:#f0f0f0;border:1px solid #ddd;"></div>Ngày nghỉ</div>
    </div>
</div>

<!-- Schedule list (compact) -->
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-list-ul me-1"></i>Danh sách lịch</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Ngày</th><th>Giờ</th><th>Slot</th><th>Trạng thái</th><th class="text-end"></th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Schedules)
                    {
                        <tr>
                            <td><strong>@s.DayOfWeek</strong></td>
                            <td>@s.StartTime — @s.EndTime</td>
                            <td>@(s.SlotDuration) phút</td>
                            <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary") bg-opacity-75">@(s.IsActive ? "Hoạt động" : "Tắt")</span></td>
                            <td class="text-end">
                                <a asp-page="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa lịch này?')"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Schedules.Any()) { <tr><td colspan="5" class="text-center py-3 text-muted">Chưa có lịch</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
