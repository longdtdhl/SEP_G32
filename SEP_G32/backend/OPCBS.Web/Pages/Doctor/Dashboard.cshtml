@page
@model OPCBS.Web.Pages.Doctor.DashboardModel
@{
    ViewData["Title"] = "Doctor Dashboard";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1>Dashboard</h1>
    <p class="text-muted">Tổng quan hoạt động tư vấn của bạn</p>
</div>

@if (Model.Error != null)
{
    <div class="alert alert-warning">@Model.Error</div>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div style="font-size:2rem;color:var(--mb-primary)"><i class="bi bi-calendar-check"></i></div>
                <h3 class="mb-0 mt-1">@Model.TotalAppointments</h3>
                <small class="text-muted">Tổng lịch hẹn</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div style="font-size:2rem;color:#e6a817"><i class="bi bi-clock-history"></i></div>
                <h3 class="mb-0 mt-1">@Model.PendingCount</h3>
                <small class="text-muted">Chờ duyệt</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div style="font-size:2rem;color:#3498db"><i class="bi bi-check-circle"></i></div>
                <h3 class="mb-0 mt-1">@Model.ApprovedCount</h3>
                <small class="text-muted">Đã duyệt</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div style="font-size:2rem;color:#27ae60"><i class="bi bi-check-all"></i></div>
                <h3 class="mb-0 mt-1">@Model.CompletedCount</h3>
                <small class="text-muted">Hoàn thành</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Upcoming Appointments -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Lịch hẹn sắp tới</h5>
                <a asp-page="/Doctor/Appointments/Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                @if (Model.UpcomingAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Bệnh nhân</th>
                                    <th>Thời gian</th>
                                    <th>Trạng thái</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var apt in Model.UpcomingAppointments)
                                {
                                    <tr>
                                        <td>
                                            <strong>@(apt.PatientName ?? "N/A")</strong>
                                            @if (!string.IsNullOrEmpty(apt.Specialization))
                                            {
                                                <br /><small class="text-muted">@apt.Specialization</small>
                                            }
                                        </td>
                                        <td>
                                            <span>@apt.StartAt.LocalDateTime.ToString("dd/MM/yyyy")</span><br />
                                            <small class="text-muted">@apt.StartAt.LocalDateTime.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            @{
                                                var badgeClass = apt.Status switch
                                                {
                                                    "Pending" => "bg-warning text-dark",
                                                    "Approved" => "bg-info text-white",
                                                    "Completed" => "bg-success",
                                                    "Cancelled" => "bg-danger",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @badgeClass">@apt.Status</span>
                                        </td>
                                        <td>
                                            <a asp-page="/Doctor/Appointments/Details" asp-route-id="@apt.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-calendar-x d-block" style="font-size:2rem"></i>
                        <p class="mt-2">Không có lịch hẹn sắp tới</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Subscription Info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-credit-card me-2"></i>Gói dịch vụ</h5>
            </div>
            <div class="card-body">
                @if (Model.CurrentSubscription != null)
                {
                    <div class="text-center">
                        <span class="badge bg-success mb-2">@Model.CurrentSubscription.Status</span>
                        <h4 class="text-primary">@(Model.CurrentSubscription.PackageName ?? "N/A")</h4>
                        <p class="text-muted mb-1">
                            <i class="bi bi-calendar3"></i>
                            @Model.CurrentSubscription.StartDate.ToString("dd/MM/yyyy") - @Model.CurrentSubscription.EndDate.ToString("dd/MM/yyyy")
                        </p>
                        <hr />
                        <a asp-page="/Doctor/Subscriptions/Status" class="btn btn-outline-primary btn-sm">Chi tiết</a>
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-credit-card-2-front d-block" style="font-size:2rem"></i>
                        <p class="mt-2">Chưa đăng ký gói dịch vụ</p>
                        <a asp-page="/Doctor/ServicePackages/Index" class="btn btn-primary btn-sm">Xem gói dịch vụ</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
