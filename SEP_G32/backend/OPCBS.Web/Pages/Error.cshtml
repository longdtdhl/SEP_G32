@page
@model OPCBS.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
    var code = Model.StatusCode;
    var title = code switch
    {
        403 => "Access Denied",
        404 => "Page Not Found",
        500 => "Server Error",
        _ => "Something Went Wrong"
    };
    var message = code switch
    {
        403 => "You do not have permission to access this resource.",
        404 => "The page you're looking for doesn't exist or has been moved.",
        500 => "An unexpected error occurred. Our team has been notified.",
        _ => "An error occurred while processing your request."
    };
    var icon = code switch
    {
        403 => "bi-shield-lock",
        404 => "bi-question-circle",
        500 => "bi-exclamation-triangle",
        _ => "bi-exclamation-circle"
    };
}

<div class="text-center py-5" style="max-width:500px;margin:0 auto;">
    <i class="bi @icon d-block mb-3" style="font-size:4rem;color:var(--mb-primary);"></i>
    @if (code.HasValue)
    {
        <p class="display-4 fw-bold mb-2" style="color:var(--mb-primary);">@code</p>
    }
    <h1 class="h3 mb-3">@title</h1>
    <p class="text-muted mb-4">@message</p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-page="/Index" class="btn btn-primary"><i class="bi bi-house me-2"></i>Go Home</a>
        <a href="javascript:history.back()" class="btn btn-outline-primary"><i class="bi bi-arrow-left me-2"></i>Go Back</a>
    </div>
</div>
