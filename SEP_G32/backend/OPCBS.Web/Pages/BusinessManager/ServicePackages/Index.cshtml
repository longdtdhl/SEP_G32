@page
@model OPCBS.Web.Pages.BusinessManager.ServicePackages.IndexModel
@{
    ViewData["Title"] = "Service Packages";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-gem me-2" style="color:var(--mb-primary);"></i>Service Package Management</h1>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Create Package</a>
</div>

@if (Model.Success != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@Model.Success<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Stats Banner -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(78,139,112,0.1);"><i class="bi bi-gem fs-4" style="color:var(--mb-primary);"></i></div>
            <div><small class="text-muted">Total</small><h4 class="mb-0 fw-bold">@Model.Packages.Count</h4></div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(16,185,129,0.1);"><i class="bi bi-check-circle fs-4 text-success"></i></div>
            <div><small class="text-muted">Active</small><h4 class="mb-0 fw-bold">@Model.Packages.Count(p => p.IsActive)</h4></div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(239,68,68,0.1);"><i class="bi bi-x-circle fs-4 text-danger"></i></div>
            <div><small class="text-muted">Inactive</small><h4 class="mb-0 fw-bold">@Model.Packages.Count(p => !p.IsActive)</h4></div>
        </div></div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(245,158,11,0.1);"><i class="bi bi-currency-dollar fs-4 text-warning"></i></div>
            <div><small class="text-muted">Avg Price</small><h4 class="mb-0 fw-bold">@(Model.Packages.Any() ? Model.Packages.Average(p => p.Price).ToString("N0") : "0")</h4></div>
        </div></div>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-semibold">Packages</h6>
        <form method="get" class="d-flex gap-2">
            <div class="input-group input-group-sm" style="width:260px;">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search packages..." />
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-filter"></i></button>
            @if (!string.IsNullOrEmpty(Model.Search)) { <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a> }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive"><table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr>
                <th class="ps-4">Package</th><th>Price</th><th>Duration</th><th>Max Appointments</th><th>Status</th><th>Created</th><th class="text-end pe-4">Actions</th>
            </tr></thead>
            <tbody>
                @if (Model.Packages.Any())
                {
                    @foreach (var pkg in Model.Packages)
                    {
                        <tr>
                            <td class="ps-4"><div><span class="fw-semibold">@pkg.Name</span><small class="text-muted d-block">@(pkg.Description?.Length > 50 ? pkg.Description[..50] + "…" : pkg.Description ?? "—")</small></div></td>
                            <td class="fw-semibold" style="color:var(--mb-primary);">@pkg.Price.ToString("N0") VND</td>
                            <td>@pkg.DurationDays days</td>
                            <td>@pkg.MaxAppointments</td>
                            <td><span class="badge @(pkg.IsActive ? "bg-success" : "bg-secondary") bg-opacity-75">@(pkg.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-muted small">@pkg.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-page="Edit" asp-route-id="@pkg.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@pkg.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this package?')"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-gem d-block mb-2" style="font-size:2.5rem;"></i><p>No service packages found.</p><a asp-page="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Create First Package</a></td></tr>
                }
            </tbody>
        </table></div>
    </div>
</div>
