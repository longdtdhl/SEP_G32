@page
@model OPCBS.Web.Pages.BusinessManager.ReportsModel
@{
    ViewData["Title"] = "Business Reports";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header"><h1><i class="bi bi-file-earmark-bar-graph me-2" style="color:var(--mb-primary);"></i>Business Reports</h1></div>
@if (Model.Error != null) { <div class="alert alert-warning">@Model.Error</div> }

<!-- Summary Banner -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm"><div class="card-body text-center py-3">
            <i class="bi bi-currency-dollar fs-3 text-success d-block mb-1"></i>
            <small class="text-muted">Revenue</small><h5 class="mb-0 fw-bold">@Model.Stats.TotalRevenue.ToString("N0") VND</h5>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm"><div class="card-body text-center py-3">
            <i class="bi bi-credit-card fs-3 d-block mb-1" style="color:#6366f1;"></i>
            <small class="text-muted">Subscriptions</small><h5 class="mb-0 fw-bold">@Model.Stats.ActiveSubscriptions</h5>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm"><div class="card-body text-center py-3">
            <i class="bi bi-person-badge fs-3 d-block mb-1" style="color:var(--mb-primary);"></i>
            <small class="text-muted">Doctors</small><h5 class="mb-0 fw-bold">@Model.Stats.TotalDoctors</h5>
        </div></div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm"><div class="card-body text-center py-3">
            <i class="bi bi-calendar-check fs-3 d-block mb-1" style="color:#ec4899;"></i>
            <small class="text-muted">Appointments</small><h5 class="mb-0 fw-bold">@Model.Stats.TotalAppointments</h5>
        </div></div>
    </div>
</div>

<!-- Report Cards -->
<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(16,185,129,0.1);"><i class="bi bi-currency-dollar fs-3 text-success"></i></div>
            <h6 class="fw-bold">Revenue Report</h6>
            <p class="text-muted small mb-3">Subscription revenue, payment trends, financial summary.</p>
            <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-download me-1"></i>Export CSV</button>
            <!-- TODO: GET /api/v1/business-manager/reports/revenue -->
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(78,139,112,0.1);"><i class="bi bi-gem fs-3" style="color:var(--mb-primary);"></i></div>
            <h6 class="fw-bold">Service Package Report</h6>
            <p class="text-muted small mb-3">Package popularity, subscription distribution, pricing analysis.</p>
            <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-download me-1"></i>Export CSV</button>
            <!-- TODO: GET /api/v1/business-manager/reports/packages -->
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(99,102,241,0.1);"><i class="bi bi-calendar-check fs-3" style="color:#6366f1;"></i></div>
            <h6 class="fw-bold">Appointment Report</h6>
            <p class="text-muted small mb-3">Booking patterns, completion rates, cancellation analysis.</p>
            <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-download me-1"></i>Export CSV</button>
            <!-- TODO: GET /api/v1/business-manager/reports/appointments -->
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(236,72,153,0.1);"><i class="bi bi-heart-pulse fs-3" style="color:#ec4899;"></i></div>
            <h6 class="fw-bold">Doctor Performance</h6>
            <p class="text-muted small mb-3">Ratings, consultations, patient satisfaction metrics.</p>
            <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-download me-1"></i>Export CSV</button>
            <!-- TODO: GET /api/v1/business-manager/reports/doctors -->
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(245,158,11,0.1);"><i class="bi bi-graph-up fs-3 text-warning"></i></div>
            <h6 class="fw-bold">Growth Analytics</h6>
            <p class="text-muted small mb-3">User growth, platform adoption, retention metrics.</p>
            <button class="btn btn-sm btn-outline-primary" disabled><i class="bi bi-bar-chart me-1"></i>View</button>
            <!-- TODO: GET /api/v1/business-manager/analytics -->
        </div></div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100"><div class="card-body text-center py-4">
            <div class="rounded-3 p-3 d-inline-flex mb-3" style="background:rgba(59,130,246,0.1);"><i class="bi bi-tags fs-3" style="color:#3b82f6;"></i></div>
            <h6 class="fw-bold">Specialization Report</h6>
            <p class="text-muted small mb-3">Doctor distribution, demand analysis per specialization.</p>
            <a asp-page="Specializations/Index" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye me-1"></i>View</a>
        </div></div>
    </div>
</div>

<div class="mt-4 text-muted small"><i class="bi bi-info-circle me-1"></i>Export features are coming soon. Report data will be available via Business Manager API.</div>
