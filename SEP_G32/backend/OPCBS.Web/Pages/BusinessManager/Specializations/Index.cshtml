@page
@model OPCBS.Web.Pages.BusinessManager.Specializations.IndexModel
@{
    ViewData["Title"] = "Specializations";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-tags me-2" style="color:var(--mb-primary);"></i>Specialization Management</h1>
    <a asp-page="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Specialization</a>
</div>

@if (Model.Success != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@Model.Success<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(78,139,112,0.1);"><i class="bi bi-tags fs-4" style="color:var(--mb-primary);"></i></div>
            <div><small class="text-muted">Total</small><h4 class="mb-0 fw-bold">@Model.Specializations.Count</h4></div>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(16,185,129,0.1);"><i class="bi bi-check-circle fs-4 text-success"></i></div>
            <div><small class="text-muted">Active</small><h4 class="mb-0 fw-bold">@Model.Specializations.Count(s => s.IsActive)</h4></div>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm"><div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(59,130,246,0.1);"><i class="bi bi-person-badge fs-4" style="color:#3b82f6;"></i></div>
            <div><small class="text-muted">Total Doctors</small><h4 class="mb-0 fw-bold">@Model.Specializations.Sum(s => s.DoctorCount)</h4></div>
        </div></div>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-semibold">Specializations</h6>
        <form method="get" class="d-flex gap-2">
            <div class="input-group input-group-sm" style="width:260px;">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search..." />
            </div>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-filter"></i></button>
            @if (!string.IsNullOrEmpty(Model.Search)) { <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a> }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive"><table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr><th class="ps-4">Name</th><th>Description</th><th>Doctors</th><th>Status</th><th class="text-end pe-4">Actions</th></tr></thead>
            <tbody>
                @if (Model.Specializations.Any())
                {
                    @foreach (var spec in Model.Specializations)
                    {
                        <tr>
                            <td class="ps-4"><div class="d-flex align-items-center gap-2"><i class="bi bi-tag" style="color:var(--mb-primary);"></i><span class="fw-semibold">@spec.Name</span></div></td>
                            <td class="text-muted small">@(spec.Description ?? "—")</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@spec.DoctorCount</span></td>
                            <td><span class="badge @(spec.IsActive ? "bg-success" : "bg-secondary") bg-opacity-75">@(spec.IsActive ? "Active" : "Inactive")</span></td>
                            <td class="text-end pe-4">
                                <a asp-page="Edit" asp-route-id="@spec.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit"><i class="bi bi-pencil"></i></a>
                                <form method="post" asp-page-handler="Delete" class="d-inline">
                                    <input type="hidden" name="id" value="@spec.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete this specialization?')"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center py-5 text-muted"><i class="bi bi-tags d-block mb-2" style="font-size:2.5rem;"></i><p>No specializations found.</p><a asp-page="Create" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Add First</a></td></tr>
                }
            </tbody>
        </table></div>
    </div>
</div>
