@page "{id:guid}"
@model OPCBS.Web.Pages.Patient.Appointments.RescheduleModel
@{
    ViewData["Title"] = "Đổi lịch hẹn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Đổi lịch hẹn</h1>
    <a asp-page="Details" asp-route-id="@ViewContext.HttpContext.Request.RouteValues["id"]" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

@if (Model.Appointment != null)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle me-1"></i>
                Lịch hẹn hiện tại: <strong>@Model.Appointment.DoctorName</strong> — @Model.Appointment.AppointmentDate @Model.Appointment.StartTime
            </div>
            <form method="post" asp-route-id="@Model.Appointment.Id">
                <div class="mb-3">
                    <label class="form-label">Lý do đổi lịch</label>
                    <textarea asp-for="Reason" class="form-control" rows="3" placeholder="Nhập lý do..."></textarea>
                </div>
                <p class="text-muted small"><i class="bi bi-info-circle me-1"></i>Vui lòng liên hệ bác sĩ để chọn slot mới phù hợp.</p>
                <button type="submit" class="btn btn-primary"><i class="bi bi-arrow-repeat me-1"></i>Gửi yêu cầu đổi lịch</button>
            </form>
        </div>
    </div>
}
