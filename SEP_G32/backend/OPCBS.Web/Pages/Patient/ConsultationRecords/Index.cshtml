@page
@model OPCBS.Web.Pages.Patient.ConsultationRecords.IndexModel
@{
    ViewData["Title"] = "Hồ sơ tư vấn";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1><i class="bi bi-file-medical me-2" style="color:var(--mb-primary);"></i>Hồ sơ tư vấn</h1>
    <p class="text-muted mb-0">Lịch sử tư vấn và chẩn đoán của bạn</p>
</div>

@if (Model.Error != null) { <div class="alert alert-warning">@Model.Error</div> }

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Records.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var record in Model.Records)
                {
                    <div class="list-group-item py-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="bi bi-person-badge me-2" style="color:var(--mb-primary);"></i>
                                    <strong>@record.DoctorName</strong>
                                    <small class="text-muted ms-3"><i class="bi bi-calendar3 me-1"></i>@record.CreatedAt.ToString("dd/MM/yyyy")</small>
                                </div>

                                @if (!string.IsNullOrEmpty(record.ConsultationSummary))
                                {
                                    <div class="mb-2">
                                        <small class="text-muted fw-semibold">Tóm tắt:</small>
                                        <p class="mb-0 small">@record.ConsultationSummary</p>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(record.Diagnosis))
                                {
                                    <div class="mb-1">
                                        <span class="badge bg-info bg-opacity-10 text-info"><i class="bi bi-clipboard2-pulse me-1"></i>Chẩn đoán: @record.Diagnosis</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(record.Recommendation))
                                {
                                    <div class="mb-1">
                                        <small class="text-muted"><i class="bi bi-lightbulb me-1"></i>Khuyến nghị: @record.Recommendation</small>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(record.FollowUpNotes))
                                {
                                    <div>
                                        <small class="text-muted"><i class="bi bi-arrow-return-right me-1"></i>Theo dõi: @record.FollowUpNotes</small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-file-earmark-medical d-block mb-2" style="font-size:2.5rem;color:var(--mb-text-muted);"></i>
                <p class="text-muted mb-0">Chưa có hồ sơ tư vấn nào</p>
            </div>
        }
    </div>
</div>
