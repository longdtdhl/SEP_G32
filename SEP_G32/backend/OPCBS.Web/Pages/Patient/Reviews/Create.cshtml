@page
@model OPCBS.Web.Pages.Patient.Reviews.CreateModel
@{
    ViewData["Title"] = "Đánh giá bác sĩ";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1><i class="bi bi-star me-2" style="color:var(--mb-primary);"></i>Đánh giá bác sĩ</h1>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Input.AppointmentId" />

                    <div class="mb-4 text-center">
                        <label class="form-label d-block fs-5 mb-3">Bạn đánh giá trải nghiệm thế nào?</label>
                        <div class="star-rating d-inline-flex gap-1" id="starRating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button" class="btn btn-link p-0 star-btn" data-value="@i"
                                        style="font-size:2.5rem;text-decoration:none;color:#ddd;" onclick="setRating(@i)">
                                    <i class="bi bi-star-fill"></i>
                                </button>
                            }
                        </div>
                        <input type="hidden" asp-for="Input.Rating" id="ratingInput" value="0" />
                        <div id="ratingText" class="text-muted mt-2">Chọn số sao</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Nhận xét (tùy chọn)</label>
                        <textarea asp-for="Input.Comment" class="form-control" rows="4"
                                  placeholder="Chia sẻ trải nghiệm tư vấn của bạn..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-send me-1"></i>Gửi đánh giá
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function setRating(value) {
        document.getElementById('ratingInput').value = value;
        const stars = document.querySelectorAll('.star-btn');
        const texts = ['', 'Rất tệ', 'Tệ', 'Bình thường', 'Tốt', 'Tuyệt vời'];
        stars.forEach((star, index) => {
            star.style.color = index < value ? '#f5a623' : '#ddd';
        });
        document.getElementById('ratingText').textContent = texts[value] || '';
        document.getElementById('ratingText').style.color = 'var(--mb-primary)';
    }
</script>
