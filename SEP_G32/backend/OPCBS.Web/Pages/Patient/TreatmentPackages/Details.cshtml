@page "{id:guid}"
@model OPCBS.Web.Pages.Patient.TreatmentPackages.DetailsModel
@{
    ViewData["Title"] = "Chi tiết gói điều trị";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center">
    <h1>Chi tiết gói điều trị</h1>
    <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

@if (Model.Error != null) { <div class="alert alert-danger">@Model.Error</div> }

@if (Model.Package != null)
{
    var pkg = Model.Package;
    var isPending = pkg.Status == "Pending" || pkg.Status == "0";
    var progress = pkg.TotalSessions > 0 ? (int)(((double)pkg.CompletedSessions / pkg.TotalSessions) * 100) : 0;

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h3 class="mb-1">@pkg.Title</h3>
                            <span class="text-muted">Bác sĩ: @(pkg.DoctorName ?? "N/A")</span>
                        </div>
                        @{
                            var badgeClass = pkg.Status switch { "Active" => "bg-success", "Pending" => "bg-warning text-dark", "Completed" => "bg-info", _ => "bg-secondary" };
                        }
                        <span class="badge @badgeClass fs-6">@pkg.Status</span>
                    </div>

                    @if (!string.IsNullOrEmpty(pkg.Description))
                    {
                        <div class="mb-4">
                            <h6>Mô tả</h6>
                            <p class="text-muted">@pkg.Description</p>
                        </div>
                    }

                    <div class="row g-3 mb-4">
                        <div class="col-sm-4">
                            <div class="p-3 rounded text-center" style="background:var(--mb-surface);">
                                <div class="fs-4 fw-bold" style="color:var(--mb-primary);">@pkg.TotalSessions</div>
                                <small class="text-muted">Tổng buổi</small>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded text-center" style="background:var(--mb-surface);">
                                <div class="fs-4 fw-bold text-success">@pkg.CompletedSessions</div>
                                <small class="text-muted">Đã hoàn thành</small>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded text-center" style="background:var(--mb-surface);">
                                <div class="fs-4 fw-bold text-info">@pkg.RemainingSessions</div>
                                <small class="text-muted">Còn lại</small>
                            </div>
                        </div>
                    </div>

                    <!-- Progress bar -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="fw-semibold">Tiến độ</small>
                            <small>@progress%</small>
                        </div>
                        <div class="progress" style="height:8px;">
                            <div class="progress-bar" style="width:@(progress)%;background:var(--mb-primary);"></div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <small class="text-muted d-block"><i class="bi bi-wallet2 me-1"></i>Phí</small>
                            <strong>@pkg.Price.ToString("N0") VND</strong>
                        </div>
                        <div class="col-sm-6">
                            <small class="text-muted d-block"><i class="bi bi-calendar-x me-1"></i>Hạn sử dụng</small>
                            <strong>@pkg.ExpirationDate.ToString("dd/MM/yyyy")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            @if (isPending)
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><h6 class="mb-0">Phản hồi</h6></div>
                    <div class="card-body d-grid gap-2">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-1"></i>Bác sĩ đã chỉ định gói điều trị này cho bạn. Vui lòng xác nhận.
                        </div>
                        <form method="post" asp-page-handler="Accept" asp-route-id="@pkg.Id">
                            <button type="submit" class="btn btn-success w-100 mb-2">
                                <i class="bi bi-check-circle me-1"></i>Chấp nhận
                            </button>
                        </form>
                        <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#rejectModal">
                            <i class="bi bi-x-circle me-1"></i>Từ chối
                        </button>
                    </div>
                </div>

                <!-- Reject Modal -->
                <div class="modal fade" id="rejectModal" tabindex="-1">
                    <div class="modal-dialog"><div class="modal-content">
                        <form method="post" asp-page-handler="Reject" asp-route-id="@pkg.Id">
                            <div class="modal-header">
                                <h5 class="modal-title">Từ chối gói điều trị</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label">Lý do từ chối</label>
                                    <textarea asp-for="RejectReason" class="form-control" rows="3" placeholder="Nhập lý do..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
                            </div>
                        </form>
                    </div></div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white"><h6 class="mb-0">Thao tác</h6></div>
                    <div class="card-body d-grid gap-2">
                        <a asp-page="/Doctors/Index" class="btn btn-primary"><i class="bi bi-calendar-plus me-1"></i>Đặt lịch tư vấn</a>
                        <a asp-page="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại danh sách</a>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-box d-block mb-2" style="font-size:3rem;color:var(--mb-text-muted);"></i>
        <h5>Không tìm thấy gói điều trị</h5>
    </div>
}
