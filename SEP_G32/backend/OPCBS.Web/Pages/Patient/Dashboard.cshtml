@page
@model OPCBS.Web.Pages.Patient.DashboardModel
@{
    ViewData["Title"] = "Tổng quan";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1><i class="bi bi-heart-pulse me-2" style="color:var(--mb-primary);"></i>Xin chào!</h1>
    <p class="text-muted mb-0">Theo dõi lịch hẹn và sức khỏe tâm lý của bạn</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="mb-stats-card"><div class="stats-icon primary"><i class="bi bi-calendar-check"></i></div><div><div class="stats-value">@Model.TotalAppointments</div><div class="stats-label">Tổng lịch hẹn</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mb-stats-card"><div class="stats-icon success"><i class="bi bi-check-circle"></i></div><div><div class="stats-value">@Model.CompletedCount</div><div class="stats-label">Đã hoàn thành</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mb-stats-card"><div class="stats-icon warning"><i class="bi bi-clock"></i></div><div><div class="stats-value">@Model.PendingCount</div><div class="stats-label">Đang chờ</div></div></div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="mb-stats-card"><div class="stats-icon info"><i class="bi bi-box-seam"></i></div><div><div class="stats-value">@Model.PackageCount</div><div class="stats-label">Gói điều trị</div></div></div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h5 class="mb-0"><i class="bi bi-calendar3 me-2"></i>Lịch hẹn sắp tới</h5></div>
            <div class="card-body p-0">
                @if (Model.UpcomingAppointments.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var apt in Model.UpcomingAppointments)
                        {
                            <a asp-page="/Patient/Appointments/Details" asp-route-id="@apt.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <div class="fw-semibold">@apt.DoctorName</div>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar-event me-1"></i>@apt.AppointmentDate
                                        <i class="bi bi-clock ms-2 me-1"></i>@apt.StartTime
                                    </small>
                                </div>
                                <partial name="_StatusBadge" view-data='@(new ViewDataDictionary(ViewData) { { "Status", apt.Status } })' />
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-calendar-x d-block mb-2" style="font-size:2.5rem;color:var(--mb-text-muted);"></i>
                        <p class="text-muted mb-3">Chưa có lịch hẹn nào</p>
                        <a asp-page="/Doctors/Index" class="btn btn-primary"><i class="bi bi-search-heart me-1"></i>Tìm chuyên gia</a>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Thao tác nhanh</h5></div>
            <div class="card-body d-grid gap-2">
                <a asp-page="/Doctors/Index" class="btn btn-primary"><i class="bi bi-search-heart me-2"></i>Tìm chuyên gia tâm lý</a>
                <a asp-page="/Patient/Appointments/Index" class="btn btn-outline-primary"><i class="bi bi-calendar me-2"></i>Lịch hẹn của tôi</a>
                <a asp-page="/Patient/ConsultationRecords/Index" class="btn btn-outline-primary"><i class="bi bi-file-medical me-2"></i>Hồ sơ tư vấn</a>
                <a asp-page="/Patient/TreatmentPackages/Index" class="btn btn-outline-primary"><i class="bi bi-box-seam me-2"></i>Gói điều trị</a>
                <a asp-page="/Blog/Index" class="btn btn-outline-secondary"><i class="bi bi-journal-text me-2"></i>Bài viết sức khỏe</a>
            </div>
        </div>
    </div>
</div>
