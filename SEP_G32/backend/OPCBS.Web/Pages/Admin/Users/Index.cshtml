@page
@model OPCBS.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Account Management";
    ViewData["UseDashboardLayout"] = true;
    var roles = new[] { "Patient", "Doctor", "CustomerSupport", "BusinessManager", "SystemAdmin" };
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-people-fill me-2" style="color:var(--mb-primary);"></i>Account Management</h1>
</div>

@if (Model.Success != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@Model.Success<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Stats Banner -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(78,139,112,0.1);"><i class="bi bi-people fs-4" style="color:var(--mb-primary);"></i></div>
                <div><small class="text-muted">Total Accounts</small><h4 class="mb-0 fw-bold">@Model.Users.Count</h4></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(16,185,129,0.1);"><i class="bi bi-person-check fs-4 text-success"></i></div>
                <div><small class="text-muted">Active</small><h4 class="mb-0 fw-bold">@Model.Users.Count(u => u.IsActive)</h4></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(239,68,68,0.1);"><i class="bi bi-person-x fs-4 text-danger"></i></div>
                <div><small class="text-muted">Locked</small><h4 class="mb-0 fw-bold">@Model.Users.Count(u => !u.IsActive)</h4></div>
            </div>
        </div>
    </div>
</div>

<!-- User Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2 py-3">
        <h6 class="mb-0 fw-semibold">Registered Users</h6>
        <!-- Search & Filter -->
        <form method="get" class="d-flex gap-2 flex-wrap">
            <div class="input-group input-group-sm" style="width:260px;">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search name, email..." />
            </div>
            <select name="role" class="form-select form-select-sm" style="width:160px;">
                <option value="">All Roles</option>
                @foreach (var r in roles) { <option value="@r" selected="@(Model.Role == r)">@r</option> }
            </select>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-filter me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Role))
            {
                <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="min-width:200px;">User</th>
                        <th>Role</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Email Verified</th>
                        <th>Created</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            var roleBadge = user.Role switch
                            {
                                "Doctor" => "bg-info bg-opacity-10 text-info",
                                "SystemAdmin" => "bg-danger bg-opacity-10 text-danger",
                                "CustomerSupport" => "bg-warning bg-opacity-10 text-warning",
                                "BusinessManager" => "bg-primary bg-opacity-10 text-primary",
                                _ => "bg-secondary bg-opacity-10 text-secondary"
                            };
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" style="width:40px;height:40px;background:var(--mb-primary);font-size:0.8rem;">
                                            @user.Initials
                                        </div>
                                        <div>
                                            <a asp-page="Details" asp-route-id="@user.Id" class="fw-semibold text-decoration-none text-dark">@user.FullName</a>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge rounded-pill @roleBadge" style="font-size:0.7rem;font-weight:600;">@(user.Role ?? "N/A")</span></td>
                                <td class="text-muted" style="font-size:0.85rem;">@user.Email</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="d-inline-flex align-items-center gap-1 text-success" style="font-size:0.85rem;"><span class="rounded-circle d-inline-block" style="width:8px;height:8px;background:var(--mb-primary);"></span>Active</span>
                                    }
                                    else
                                    {
                                        <span class="d-inline-flex align-items-center gap-1 text-danger" style="font-size:0.85rem;"><span class="rounded-circle d-inline-block" style="width:8px;height:8px;background:#EF4444;"></span>Locked</span>
                                    }
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle text-muted"></i>
                                    }
                                </td>
                                <td class="text-muted" style="font-size:0.85rem;">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end pe-4">
                                    <a asp-page="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1" title="View"><i class="bi bi-eye"></i></a>
                                    @if (user.IsActive)
                                    {
                                        <form method="post" asp-page-handler="Lock" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Lock" onclick="return confirm('Lock this user account?')"><i class="bi bi-lock"></i></button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Unlock" class="d-inline">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Unlock" onclick="return confirm('Unlock this user account?')"><i class="bi bi-unlock"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="text-center py-5 text-muted">
                                    <i class="bi bi-people d-block mb-2" style="font-size:2.5rem;"></i>
                                    <p class="mb-0">No users found matching your criteria.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Pagination.Page of @Model.Pagination.TotalPages (@Model.Pagination.TotalItems users)</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                            <a class="page-link" asp-page="Index" asp-route-page="@i" asp-route-search="@Model.Search" asp-route-role="@Model.Role">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
