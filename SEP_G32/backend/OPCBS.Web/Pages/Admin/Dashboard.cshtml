@page
@model OPCBS.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header">
    <h1><i class="bi bi-speedometer2 me-2" style="color:var(--mb-primary);"></i>System Admin Dashboard</h1>
</div>

@if (Model.Error != null) { <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error</div> }

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(78,139,112,0.1);">
                    <i class="bi bi-people-fill fs-4" style="color:var(--mb-primary);"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Total Users</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.TotalUsers</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(16,185,129,0.1);">
                    <i class="bi bi-person-badge fs-4 text-success"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Doctors</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.TotalDoctors</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(245,158,11,0.1);">
                    <i class="bi bi-hourglass-split fs-4 text-warning"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Pending Verifications</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.PendingVerifications</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(99,102,241,0.1);">
                    <i class="bi bi-calendar-check fs-4" style="color:#6366f1;"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Appointments</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.TotalAppointments</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Second row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(59,130,246,0.1);">
                    <i class="bi bi-heart-pulse fs-4" style="color:#3b82f6;"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Patients</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.TotalPatients</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(236,72,153,0.1);">
                    <i class="bi bi-journal-check fs-4" style="color:#ec4899;"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Pending Blogs</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.PendingBlogApprovals</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(16,185,129,0.1);">
                    <i class="bi bi-credit-card fs-4 text-success"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Active Subscriptions</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.ActiveSubscriptions</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:rgba(245,158,11,0.1);">
                    <i class="bi bi-currency-dollar fs-4 text-warning"></i>
                </div>
                <div>
                    <small class="text-muted d-block">Total Revenue</small>
                    <h3 class="mb-0 fw-bold">@Model.Stats.TotalRevenue.ToString("N0") <small class="fs-6 fw-normal">VND</small></h3>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-lightning me-1"></i>Quick Actions</h6></div>
            <div class="card-body d-grid gap-2">
                <a asp-page="Users/Index" class="btn btn-outline-primary text-start"><i class="bi bi-people me-2"></i>Manage Users</a>
                <a asp-page="Roles/Index" class="btn btn-outline-primary text-start"><i class="bi bi-shield-check me-2"></i>View Roles</a>
                <a asp-page="AuditLogs/Index" class="btn btn-outline-primary text-start"><i class="bi bi-journal-text me-2"></i>View Audit Logs</a>
                <a asp-page="Reports" class="btn btn-outline-primary text-start"><i class="bi bi-file-earmark-bar-graph me-2"></i>Reports</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-info-circle me-1"></i>System Info</h6></div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tr><td class="text-muted">Platform</td><td class="fw-semibold">MindBridge v1.0</td></tr>
                    <tr><td class="text-muted">Environment</td><td class="fw-semibold">Development</td></tr>
                    <tr><td class="text-muted">Server Time</td><td class="fw-semibold">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><td class="text-muted border-0">Framework</td><td class="fw-semibold border-0">.NET 8</td></tr>
                </table>
            </div>
        </div>
    </div>
</div>
