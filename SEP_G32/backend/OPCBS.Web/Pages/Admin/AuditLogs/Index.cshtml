@page
@model OPCBS.Web.Pages.Admin.AuditLogs.IndexModel
@{
    ViewData["Title"] = "Audit Logs";
    ViewData["UseDashboardLayout"] = true;
    var entities = new[] { "User", "Appointment", "Schedule", "Blog", "ConsultationRecord", "TreatmentPackage", "Verification", "ServicePackage", "Subscription" };
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-journal-text me-2" style="color:var(--mb-primary);"></i>Audit Logs</h1>
</div>

@if (Model.Error != null) { <div class="alert alert-warning">@Model.Error</div> }

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2 py-3">
        <h6 class="mb-0 fw-semibold">System Activity Log</h6>
        <form method="get" class="d-flex gap-2">
            <select name="entityName" class="form-select form-select-sm" style="width:180px;">
                <option value="">All Entities</option>
                @foreach (var e in entities) { <option value="@e" selected="@(Model.EntityName == e)">@e</option> }
            </select>
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-filter me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(Model.EntityName))
            {
                <a asp-page="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
            }
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Details</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Logs.Any())
                    {
                        @foreach (var log in Model.Logs)
                        {
                            var actionColor = log.Action?.ToLower() switch
                            {
                                var a when a != null && a.Contains("create") => "text-success",
                                var a when a != null && a.Contains("delete") => "text-danger",
                                var a when a != null && a.Contains("update") => "text-primary",
                                var a when a != null && a.Contains("lock") => "text-warning",
                                _ => "text-secondary"
                            };
                            <tr>
                                <td class="ps-4 text-muted" style="font-size:0.8rem;white-space:nowrap;">@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td style="font-size:0.85rem;">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:28px;height:28px;">
                                            <i class="bi bi-person-fill text-secondary" style="font-size:0.7rem;"></i>
                                        </div>
                                        <span>@(log.UserName ?? "System")</span>
                                    </div>
                                </td>
                                <td><span class="fw-semibold @actionColor" style="font-size:0.85rem;">@log.Action</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.EntityType))
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:0.65rem;">@log.EntityType</span>
                                    }
                                </td>
                                <td class="text-muted" style="font-size:0.8rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(log.Details ?? "—")</td>
                                <td class="text-muted" style="font-size:0.8rem;">@(log.IpAddress ?? "—")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-journal d-block mb-2" style="font-size:2rem;"></i><p>No audit logs found.</p></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Pagination.Page of @Model.Pagination.TotalPages</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Math.Min(Model.Pagination.TotalPages, 10); i++)
                    {
                        <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                            <a class="page-link" asp-page="Index" asp-route-page="@i" asp-route-entityName="@Model.EntityName">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
