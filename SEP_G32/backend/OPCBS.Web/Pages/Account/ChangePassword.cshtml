@page
@model OPCBS.Web.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="mb-auth-container">
    <div class="mb-auth-card">
        <h2>Change Password</h2>
        <p class="auth-subtitle">Update your account password.</p>
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input asp-for="Input.CurrentPassword" type="password" class="form-control" />
            </div>
            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input asp-for="Input.NewPassword" type="password" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Update Password</button>
        </form>
    </div>
</div>
