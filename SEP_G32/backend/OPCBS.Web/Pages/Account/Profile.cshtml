@page
@model OPCBS.Web.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div style="max-width:640px;margin:0 auto;">
    <div class="card">
        <div class="card-body">
            <h2 class="mb-4">My Profile</h2>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
            <form method="post">
                <div class="text-center mb-4">
                    <div class="rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:96px;height:96px;background-color:var(--mb-secondary);">
                        <i class="bi bi-person-fill" style="font-size:2.5rem;color:var(--mb-primary);"></i>
                    </div>
                    <p class="text-muted mb-0" style="font-size:0.875rem;">@Model.Email</p>
                </div>
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input asp-for="Input.FullName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone Number</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select asp-for="Input.Gender" class="form-select">
                            <option value="">Select</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date of Birth</label>
                        <input asp-for="Input.DateOfBirth" type="date" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <input asp-for="Input.Address" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
    </div>
</div>
