@* Error state partial — pass ViewData["ErrorMessage"] *@
@{
    var errorMsg = ViewData["ErrorMessage"] as string ?? "Something went wrong. Please try again later.";
}
<div class="mb-error-state">
    <i class="bi bi-exclamation-triangle d-block"></i>
    <h5 class="text-danger mt-2">Error</h5>
    <p class="text-muted">@errorMsg</p>
    <a href="javascript:location.reload()" class="btn btn-outline-primary btn-sm mt-2">
        <i class="bi bi-arrow-clockwise me-1"></i>Try Again
    </a>
</div>
