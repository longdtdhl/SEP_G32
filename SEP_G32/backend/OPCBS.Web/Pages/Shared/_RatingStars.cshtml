@* Rating stars partial — pass ViewData["Rating"] as double (0-5) and ViewData["ReviewCount"] as int *@
@{
    var rating = ViewData["Rating"] is double r ? r : 0;
    var count = ViewData["ReviewCount"] is int c ? c : 0;
    var fullStars = (int)Math.Floor(rating);
    var hasHalf = rating - fullStars >= 0.5;
}
<span class="mb-rating" title="@rating.ToString("F1") out of 5">
    @for (int i = 0; i < fullStars; i++)
    {
        <i class="bi bi-star-fill"></i>
    }
    @if (hasHalf)
    {
        <i class="bi bi-star-half"></i>
    }
    @for (int i = fullStars + (hasHalf ? 1 : 0); i < 5; i++)
    {
        <i class="bi bi-star star-empty"></i>
    }
    @if (count > 0)
    {
        <small class="ms-1 text-muted" style="font-size:0.8125rem;">(@count)</small>
    }
</span>
