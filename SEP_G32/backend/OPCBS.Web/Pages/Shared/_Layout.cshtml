<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindBridge</title>
    <meta name="description" content="MindBridge — Connecting Minds, Supporting Wellbeing. Professional mental health counseling platform." />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- MindBridge CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OPCBS.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Header -->
    <header>
        <partial name="_Header" />
    </header>

    <!-- Flash message data (for JS toast) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="mb-flash-message" data-type="success" data-message="@TempData["SuccessMessage"]" style="display:none;"></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="mb-flash-message" data-type="error" data-message="@TempData["ErrorMessage"]" style="display:none;"></div>
    }

    <!-- Main Content -->
    @if (ViewData["UseDashboardLayout"] as bool? == true)
    {
        <!-- Dashboard Layout with Sidebar -->
        <partial name="_Sidebar" />
        <div class="mb-dashboard-content">
            @RenderBody()
        </div>
    }
    else
    {
        <!-- Standard Content Layout -->
        <div class="container py-4">
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <!-- Footer (only for non-dashboard pages) -->
        <footer>
            <partial name="_Footer" />
        </footer>
    }

    <!-- Scroll to top button -->
    <button id="scroll-to-top" class="scroll-to-top" aria-label="Scroll to top">
        <i class="bi bi-arrow-up"></i>
    </button>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>