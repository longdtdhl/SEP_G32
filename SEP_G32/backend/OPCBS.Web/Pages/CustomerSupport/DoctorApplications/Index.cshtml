@page
@model OPCBS.Web.Pages.CustomerSupport.DoctorApplications.IndexModel
@{
    ViewData["Title"] = "Doctor Applications";
    ViewData["UseDashboardLayout"] = true;
    var statuses = new[] { "Pending", "Approved", "Rejected" };
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-person-check me-2" style="color:var(--mb-primary);"></i>Doctor Applications</h1>
</div>

@{ var s = TempData["Success"] as string; }
@if (s != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@s<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <span class="text-muted small me-2">Filter by status:</span>
            <a asp-page="Index" class="btn btn-sm @(string.IsNullOrEmpty(Model.Status) ? "btn-primary" : "btn-outline-secondary")">All</a>
            @foreach (var st in statuses)
            {
                var cls = st == Model.Status ? "btn-primary" : "btn-outline-secondary";
                <a asp-page="Index" asp-route-status="@st" class="btn btn-sm @cls">@st</a>
            }
        </form>
    </div>
</div>

<!-- Applications Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h6 class="mb-0 fw-semibold">Applications Queue</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive"><table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr>
                <th class="ps-4">Doctor</th><th>Specialization</th><th>License</th><th>Experience</th><th>Status</th><th>Submitted</th><th class="text-end pe-4">Action</th>
            </tr></thead>
            <tbody>
                @if (Model.Applications.Any())
                {
                    @foreach (var app in Model.Applications)
                    {
                        var badgeClass = app.Status?.ToLower() switch { "pending" => "bg-warning text-dark", "approved" => "bg-success", "rejected" => "bg-danger", _ => "bg-secondary" };
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" style="width:36px;height:36px;background:var(--mb-primary);font-size:0.75rem;">
                                        @(app.DoctorName?.Split(' ').Select(w => w[0]).Take(2).Aggregate("", (a, c) => a + c).ToUpper() ?? "?")
                                    </div>
                                    <span class="fw-semibold">@(app.DoctorName ?? "Unknown")</span>
                                </div>
                            </td>
                            <td class="small">@(app.Specialization ?? "—")</td>
                            <td class="small text-muted">@(app.LicenseNumber ?? "—")</td>
                            <td class="small">@app.ExperienceYears years</td>
                            <td><span class="badge @badgeClass" style="font-size:0.65rem;">@(app.Status ?? "Pending")</span></td>
                            <td class="small text-muted">@app.SubmittedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-page="Details" asp-route-id="@app.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye me-1"></i>Review</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-person-check d-block mb-2" style="font-size:2.5rem;"></i><p>No applications found.</p></td></tr>
                }
            </tbody>
        </table></div>
    </div>
    @if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Pagination.Page of @Model.Pagination.TotalPages</small>
            <nav><ul class="pagination pagination-sm mb-0">
                @for (int i = 1; i <= Math.Min(Model.Pagination.TotalPages, 10); i++)
                {
                    <li class="page-item @(i == Model.Pagination.Page ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-page="@i" asp-route-status="@Model.Status">@i</a>
                    </li>
                }
            </ul></nav>
        </div>
    }
</div>
