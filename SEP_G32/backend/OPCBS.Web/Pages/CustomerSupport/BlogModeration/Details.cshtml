@page "{id:guid}"
@model OPCBS.Web.Pages.CustomerSupport.BlogModeration.DetailsModel
@{
    ViewData["Title"] = "Blog Review";
    ViewData["UseDashboardLayout"] = true;
}

@{ var suc = TempData["Success"] as string; }
@if (suc != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@suc<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

@if (Model.Blog == null)
{
    <div class="mb-page-header"><h1>Blog Not Found</h1></div>
    <div class="text-center py-5 text-muted"><i class="bi bi-journal-x d-block mb-2" style="font-size:3rem;"></i><p>This blog could not be found.</p><a asp-page="Index" class="btn btn-primary"><i class="bi bi-arrow-left me-1"></i>Back</a></div>
    return;
}

@{ var blog = Model.Blog; var isPending = blog.Status?.Equals("PendingApproval", StringComparison.OrdinalIgnoreCase) == true || blog.Status?.Equals("Pending", StringComparison.OrdinalIgnoreCase) == true; }

<div class="mb-page-header d-flex align-items-center gap-3">
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h1 class="mb-0"><i class="bi bi-journal-text me-2" style="color:var(--mb-primary);"></i>Blog Review</h1>
</div>

<div class="row g-4">
    <!-- Blog Content -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(blog.ImageUrl))
                {
                    <img src="@blog.ImageUrl" alt="@blog.Title" class="w-100 mb-3 rounded" style="max-height:300px;object-fit:cover;" />
                }

                @if (!string.IsNullOrEmpty(blog.Category))
                {
                    <span class="badge bg-primary bg-opacity-10 text-primary mb-2">@blog.Category</span>
                }

                <h3 class="fw-bold mb-2">@blog.Title</h3>

                <div class="d-flex gap-3 text-muted small mb-3">
                    <span><i class="bi bi-person me-1"></i>@(blog.AuthorName ?? "Unknown")</span>
                    <span><i class="bi bi-calendar me-1"></i>@blog.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                </div>

                @if (!string.IsNullOrEmpty(blog.Summary))
                {
                    <div class="alert alert-light mb-3"><strong>Summary:</strong> @blog.Summary</div>
                }

                @if (blog.Tags.Any())
                {
                    <div class="mb-3">
                        @foreach (var tag in blog.Tags) { <span class="badge bg-secondary bg-opacity-10 text-secondary me-1">@tag</span> }
                    </div>
                }

                <hr />
                <div class="blog-content" style="line-height:1.8;">
                    @Html.Raw(blog.Content)
                </div>
            </div>
        </div>
    </div>

    <!-- Moderation Sidebar -->
    <div class="col-lg-4">
        <!-- Status -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-info-circle me-1"></i>Moderation Status</h6></div>
            <div class="card-body">
                @{
                    var badgeClass = blog.Status?.ToLower() switch { "pending" or "pendingapproval" => "bg-warning text-dark", "approved" or "published" => "bg-success", "rejected" => "bg-danger", _ => "bg-secondary" };
                }
                <div class="d-flex justify-content-between mb-2"><span class="text-muted small">Status</span><span class="badge @badgeClass">@(blog.Status ?? "Pending")</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted small">Author</span><span class="small fw-medium">@(blog.AuthorName ?? "—")</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted small">Category</span><span class="small fw-medium">@(blog.Category ?? "—")</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted small">Created</span><span class="small">@blog.CreatedAt.ToString("dd/MM/yyyy")</span></div>
                @if (blog.UpdatedAt.HasValue)
                {
                    <div class="d-flex justify-content-between"><span class="text-muted small">Updated</span><span class="small">@blog.UpdatedAt.Value.ToString("dd/MM/yyyy")</span></div>
                }
            </div>
        </div>

        <!-- Actions -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-clipboard-check me-1"></i>Review Actions</h6></div>
            <div class="card-body">
                @if (isPending)
                {
                    <form method="post" asp-page-handler="Approve" asp-route-id="@blog.Id" class="mb-3">
                        <button type="submit" class="btn btn-success w-100" onclick="return confirm('Approve and publish this blog?')">
                            <i class="bi bi-check-circle me-1"></i>Approve & Publish
                        </button>
                    </form>

                    <form method="post" asp-page-handler="Reject" asp-route-id="@blog.Id">
                        <div class="mb-2">
                            <label class="form-label small fw-semibold">Rejection Reason</label>
                            <textarea asp-for="RejectReason" class="form-control" rows="3" placeholder="Optional reason for rejection..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Reject this blog?')">
                            <i class="bi bi-x-circle me-1"></i>Reject Blog
                        </button>
                    </form>
                }
                else
                {
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-check-all d-block mb-2" style="font-size:2rem;"></i>
                        <p class="mb-0">This blog has been <strong>@blog.Status?.ToLower()</strong>.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
