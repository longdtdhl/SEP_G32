@page
@model OPCBS.Web.Pages.CustomerSupport.BlogModeration.IndexModel
@{
    ViewData["Title"] = "Blog Moderation";
    ViewData["UseDashboardLayout"] = true;
}

<div class="mb-page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1><i class="bi bi-journal-text me-2" style="color:var(--mb-primary);"></i>Blog Moderation Queue</h1>
</div>

@if (ViewData["Success"] is string suc) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-1"></i>@suc<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
@if (Model.Error != null) { <div class="alert alert-warning alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-1"></i>@Model.Error<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }

<!-- Blog Queue -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h6 class="mb-0 fw-semibold">Pending Blog Articles</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive"><table class="table table-hover align-middle mb-0">
            <thead class="table-light"><tr>
                <th class="ps-4" style="min-width:250px;">Article</th><th>Author</th><th>Category</th><th>Status</th><th>Submitted</th><th class="text-end pe-4">Action</th>
            </tr></thead>
            <tbody>
                @if (Model.Blogs.Any())
                {
                    @foreach (var blog in Model.Blogs)
                    {
                        var badgeClass = blog.Status?.ToLower() switch { "pending" or "pendingapproval" => "bg-warning text-dark", "approved" or "published" => "bg-success", "rejected" => "bg-danger", _ => "bg-secondary" };
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(blog.ImageUrl))
                                    {
                                        <img src="@blog.ImageUrl" alt="" class="rounded" style="width:48px;height:48px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:rgba(78,139,112,0.1);"><i class="bi bi-journal" style="color:var(--mb-primary);"></i></div>
                                    }
                                    <div>
                                        <span class="fw-semibold small">@(blog.Title.Length > 45 ? blog.Title[..45] + "…" : blog.Title)</span>
                                        <small class="text-muted d-block">@(blog.Summary?.Length > 60 ? blog.Summary[..60] + "…" : blog.Summary ?? "—")</small>
                                    </div>
                                </div>
                            </td>
                            <td class="small">@(blog.AuthorName ?? "Unknown")</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:0.6rem;">@(blog.Category ?? "General")</span></td>
                            <td><span class="badge @badgeClass" style="font-size:0.65rem;">@(blog.Status ?? "Pending")</span></td>
                            <td class="small text-muted">@blog.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end pe-4">
                                <a asp-page="Details" asp-route-id="@blog.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye me-1"></i>Review</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-journal-check d-block mb-2" style="font-size:2.5rem;"></i><p>No blogs pending moderation.</p></td></tr>
                }
            </tbody>
        </table></div>
    </div>
    @if (Model.Pagination != null && Model.Pagination.TotalPages > 1)
    {
        <div class="card-footer bg-white d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Pagination.Page of @Model.Pagination.TotalPages</small>
            <nav><ul class="pagination pagination-sm mb-0">
                @for (int i = 1; i <= Math.Min(Model.Pagination.TotalPages, 10); i++)
                {
                    <li class="page-item @(i == Model.Pagination.Page ? "active" : "")"><a class="page-link" asp-page="Index" asp-route-page="@i">@i</a></li>
                }
            </ul></nav>
        </div>
    }
</div>
