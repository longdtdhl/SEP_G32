{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-frontend",
			"type": "npm",
			"script": "build",
			"path": "SEP_G32/frontend",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			}
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/SEP_G32/backend/OPCBS.Web/OPCBS.Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/SEP_G32/backend/OPCBS.Web/OPCBS.Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/SEP_G32/backend/OPCBS.Web/OPCBS.Web.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
	]
}